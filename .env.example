# GameDev MCP Hub - Environment Variables
# Copy this file to .env and fill in your actual values

# === OBSIDIAN ===
OBSIDIAN_API_KEY=your-obsidian-api-key-here

# === GITHUB ===
# Get token from: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:org, user
GITHUB_PERSONAL_ACCESS_TOKEN=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

# === GODOT ===
# Path to your Godot project (optional - only if using Godot)
GODOT_PROJECT_PATH=/home/yourusername/projects/cognitivemill

# === THINGIVERSE ===
# Get token from: https://www.thingiverse.com/apps/create
THINGIVERSE_API_TOKEN=3441ce4bd312c21d1b8d0be0c7b460cc

# === BLENDER ===
BLENDER_HOST=localhost
BLENDER_PORT=9876

# === DISCORD === (if enabling Discord server)
#DISCORD_BOT_TOKEN=your_discord_bot_token

# === UNITY === (if enabling Unity server)
#UNITY_PROJECT_PATH=C:\Path\To\Unity\Project

# === GITHUB (if enabling GitHub server) ===
#GITHUB_TOKEN=your_github_token

# Add more environment variables as you enable more servers
